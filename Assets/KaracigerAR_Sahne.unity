  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "G\xDCNL\xDCK BESLENME PROGRAMI\n\n[SABAH]\n\u2022 2 adet ha\u015Flanm\u0131\u015F
    yumurta beyaz\u0131\n\u2022 1 dilim tam bu\u011Fday ekme\u011Fi\n\u2022 Tuzsuz
    lor peyniri ve bol ye\u015Fillik\n\n[\xD6\u011ELE]\n\u2022 Zeytinya\u011Fl\u0131
    enginar veya \u0131zgara tavuk g\xF6\u011Fs\xFC\n\u2022 1 kase probiyotik yo\u011Furt\n\u2022
    K\xFC\xE7\xFCk porsiyon karabu\u011Fday pilav\u0131\n\n[ARA \xD6\u011E\xDCN]\n\u2022
    1 avu\xE7 \xE7i\u011F badem veya 1 adet ye\u015Fil elma\n\u2022 (\xD6NEML\u0130:
    Ara \xF6\u011F\xFCnleri asla atlama, kan \u015Fekerini dengede tutar!)\n\n[AK\u015EAM]\n\u2022
    F\u0131r\u0131nda pi\u015Fmi\u015F somon veya bu\u011Fulama bal\u0131k\n\u2022
    Ha\u015Flanm\u0131\u015F brokoli\n\u2022 Bol limonlu, az zeytinya\u011Fl\u0131
    ye\u015Fil salata\n\n---\n\u274C YENMEMES\u0130 GEREKENLER (SAKIN T\xDCKETME!)\n\u2022
    Alkol: Karaci\u011Ferin en b\xFCy\xFCk d\xFC\u015Fman\u0131.\n\u2022 Sodyum:
    Haz\u0131r \xE7orbalar, cipsler, salamura g\u0131dalar (\xF6dem yapar).\n\u2022
    \u0130\u015Flenmi\u015F Etler: Salam, sucuk, sosis.\n\u2022 K\u0131zartmalar:
    Her t\xFCrl\xFC a\u011F\u0131r ya\u011Fl\u0131 k\u0131zartma.\n\u2022 \u015Eekerli
    \u0130\xE7ecekler: Asitli, \u015Fekerli t\xFCm paketli g\u0131dalar."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
